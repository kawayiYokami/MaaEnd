{
    "MapTrackerTestLoop": {
        "doc": "此节点用于持续运行小地图定位，可与路径编辑工具结合使用",
        "rate_limit": 500,
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "MapTrackerInfer",
                "custom_recognition_param": {
                    "map_name_regex": ".*",
                    "precision": 0.8,
                    "print": true
                }
            }
        },
        "max_hit": 3600,
        "next": [
            "MapTrackerTestLoop"
        ]
    },
    "MapTrackerTest": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "MapTrackerInfer",
                "custom_recognition_param": {
                    "map_name_regex": ".*",
                    "precision": 0.8,
                    "print": true
                }
            }
        }
    }
}
