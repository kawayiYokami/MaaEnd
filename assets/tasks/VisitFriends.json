{
    "task": [
        {
            "name": "VisitFriends",
            "label": "$task.VisitFriends.label",
            "entry": "VisitFriendsMain",
            "description": "$task.VisitFriends.description",
            "option": [
                "ProductionAssistType"
            ],
            "controller": [
                "Win32-Window",
                "Win32-Window-Background",
                "Win32-Front"
            ],
            "group": [
                "daily"
            ]
        }
    ],
    "option": {
        "ProductionAssistType": {
            "type": "select",
            "label": "$option.ProductionAssistType.label",
            "default_case": "ProductionAssistAll",
            "cases": [
                {
                    "name": "ProductionAssistAll",
                    "label": "$option.ProductionAssistType.ProductionAssistAll.label"
                },
                {
                    "name": "ProductionAssistOnlyGrowthChamber",
                    "label": "$option.ProductionAssistType.ProductionAssistOnlyGrowthChamber.label",
                    "pipeline_override": {
                        "VisitFriendsMenuScanTargetFriendOpen": {
                            "custom_recognition_param": {
                                "assist_mode": "only_growth_chamber"
                            }
                        }
                    }
                },
                {
                    "name": "ProductionAssistWithoutControlNexus",
                    "label": "$option.ProductionAssistType.ProductionAssistWithoutControlNexus.label",
                    "pipeline_override": {
                        "VisitFriendsMenuScanTargetFriendOpen": {
                            "custom_recognition_param": {
                                "assist_mode": "without_control_nexus"
                            }
                        }
                    }
                }
            ]
        }
    }
}
